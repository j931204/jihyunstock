rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Catch-All Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Validation Helpers
    function isOwner(userId) {
      return (request.auth != null && request.auth.uid == userId) || userId == 'default-user';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. User Profile Entity Hardening function
    function isValidUserProfile(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.userId.matches('^[a-zA-Z0-9_\\-+]+$')
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && data.totalDeposits is number
        && data.totalDeposits >= 0
        && data.cashBalance is number
        && data.cashBalance >= -1000000000
        && data.keys().hasAll(['userId', 'totalDeposits', 'cashBalance'])
        && (data.updatedAt == null || data.updatedAt is timestamp);
    }

    // 3. Trade Record Entity Hardening function
    function isValidTrade(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.userId.matches('^[a-zA-Z0-9_\\-+]+$')
        && data.ticker is string
        && data.ticker.size() > 0
        && data.ticker.size() <= 30
        && data.companyName is string
        && data.companyName.size() <= 200
        && (data.type == 'BUY' || data.type == 'SELL')
        && data.quantity is number
        && data.quantity > 0
        && data.price is number
        && data.price > 0
        && (data.reason == null || (data.reason is string && data.reason.size() <= 500))
        && data.keys().hasAll(['userId', 'ticker', 'type', 'quantity', 'price'])
        && (data.date == null || data.date is timestamp)
        && (data.createdAt == null || data.createdAt is timestamp);
    }

    // 4. Endpoint Rules: User Profiles (Relational Isolation)
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    // 5. Endpoint Rules: Stock Trades (PII and Identity Guards)
    match /trades/{tradeId} {
      // Secure list query checks - require owner relationship on resource.data
      allow read: if isOwner(resource.data.userId);
      
      allow create: if isOwner(incoming().userId) && isValidTrade(incoming());
      
      allow update: if isOwner(existing().userId) 
        && isOwner(incoming().userId)
        && isValidTrade(incoming()) 
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if isOwner(existing().userId);
    }
  }
}
